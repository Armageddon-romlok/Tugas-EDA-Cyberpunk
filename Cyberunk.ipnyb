    },
    {
      "cell_type": "markdown",
      "source": [
        "## **DISTRIBUTION / DISTRIBUSI**"
      ],
      "metadata": {
        "id": "yjjFNMrpChrb"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "plt.figure(figsize=(10, 6))\n",
        "sns.histplot(df['PEAK PLAYERS'], bins=20, kde=True)\n",
        "plt.title('Distribusi Jumlah Peak Players Bulanan')\n",
        "plt.xlabel('Jumlah Peak Players')\n",
        "plt.ylabel('Frekuensi (Bulan)')\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 564
