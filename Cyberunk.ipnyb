    },
    {
      "cell_type": "markdown",
      "source": [
        "## **RELATIONSHIP / HUBUNGAN**"
      ],
      "metadata": {
        "id": "oX0APWuBCrQO"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "plt.figure(figsize=(8, 6))\n",
        "sns.heatmap(data=df[['Tahun', 'Bulan_Angka', 'PEAK PLAYERS']].corr(),\n",
        "            annot=True,\n",
        "            cmap='coolwarm',\n",
        "            fmt='.2f')\n",
        "plt.title('Korelasi antara Waktu dan Jumlah Pemain')\n",
        "plt.show()"
      ],
      "metadata": {
