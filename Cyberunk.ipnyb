    {
      "cell_type": "markdown",
      "source": [
        "# **Persiapan Data**"
      ],
      "metadata": {
        "id": "eK5nKHlLB2IG"
      }
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "id": "SqGjgvfv988x"
      },
      "outputs": [],
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "df = pd.read_csv('CYBERPUNK 2077 STEAM Chart - Players Over The Year.csv')\n",
        "df['PEAK PLAYERS'] = df['PEAK PLAYERS'].str.replace(',', '').astype(int)\n",
        "df['DATETIME'] = pd.to_datetime(df['DATE'], format='%Y %B')\n",
        "df['Tahun'] = df['DATETIME'].dt.year\n",
        "df['Bulan_Angka'] = df['DATETIME'].dt.month"
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "# **EDA**"
      ],
      "metadata": {
        "id": "ktvPJ5HrCIvU"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## **COMPARISON / PERBANDINGAN**"
      ],
      "metadata": {
        "id": "6MLPTLc7CYaw"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "variabel = df.groupby('Tahun')['PEAK PLAYERS'].sum().sort_values(ascending=False)\n",
        "\n",
        "plt.figure(figsize=(10,6))\n",
        "sns.barplot(x=variabel.index, y=variabel.values, palette='viridis')\n",
        "plt.title('Perbandingan Total Peak Players per Tahun')\n",
        "plt.xlabel('Tahun')\n",
        "plt.ylabel('Total Peak Players')\n",
        "plt.xticks(rotation=45)\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 672
        },
        "id": "Bi8X1Sid-XjN",
        "outputId": "6acec537-02fd-4dee-b2bb-9f127187d335"
      },
