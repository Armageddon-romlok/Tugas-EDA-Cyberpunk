    {
      "cell_type": "markdown",
      "source": [
        "## **COMPOSITION / KOMPOSISI**"
      ],
      "metadata": {
        "id": "GJDC7m9MCdpQ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "variabel = df.groupby('Tahun')['PEAK PLAYERS'].sum().sort_values(ascending=False)\n",
        "variabel2 = variabel.head(3)\n",
        "\n",
        "plt.figure(figsize=(10, 8))\n",
        "variabel2.plot(kind='pie', autopct='%1.1f%%', startangle=140, colors=plt.cm.Paired.colors)\n",
        "plt.title('Komposisi 3 Tahun dengan Pemain Terbanyak')\n",
        "plt.ylabel('')\n",
        "plt.axis('equal')\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 675
        },
